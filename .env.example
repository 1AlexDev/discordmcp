# Discord Application (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_TOKEN=

# Optional — defaults to {BASE_URL}/callback when unset
# DISCORD_REDIRECT_URI=https://your-app.onrender.com/callback

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public-facing origin (no trailing slash)
# Local: http://localhost:3000
# Render: https://your-app.onrender.com
BASE_URL=http://localhost:3000

# Render injects PORT automatically; default 3000 for local dev
PORT=3000
NODE_ENV=development

# MCP transport: "sse" for production/Render (default), "stdio" for local Cursor
MCP_TRANSPORT=sse

# Required in production — HMAC secret for OAuth state signing
OAUTH_STATE_SECRET=
